# Procore OAuth credentials
PROCORE_CLIENT_ID=your_client_id_here
PROCORE_CLIENT_SECRET=your_client_secret_here

# Optional: Override defaults
# PROCORE_BASE_URL=https://api.procore.com
# PROCORE_AUTH_URL=https://login.procore.com/oauth/token

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Session secret (change in production!)
SESSION_SECRET=change-me-in-production

# Debug mode
DEBUG=true

# Procore Documents folder ID for uploaded submittal files
# Find this in Procore > Documents > right-click folder > Properties > ID
PROCORE_UPLOAD_FOLDER_ID=0
